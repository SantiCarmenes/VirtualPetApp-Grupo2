{
  "expo": {
    "name": "delivery-app",
    "slug": "delivery-app",
    "owner": "virtualpet-das",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/iconoapp.png",
    "userInterfaceStyle": "light",
    "scheme": "deliveryapp",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1e3a5f",
        "foregroundImage": "./assets/iconoapp.png"
      },
      "predictiveBackGestureEnabled": false,
      "newArchEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.santicarmenes.deliveryapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Permitir que $(PRODUCT_NAME) use tu ubicación en todo momento para el ruteo de entregas.",
          "locationWhenInUsePermission": "Permitir que $(PRODUCT_NAME) use tu ubicación mientras usás la app.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir que $(PRODUCT_NAME) acceda a la cámara para capturar comprobantes de entrega."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "236fa160-fd97-405d-b6db-e47e267a23ed"
      }
    }
  }
}